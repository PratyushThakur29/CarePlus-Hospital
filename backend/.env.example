# Django
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com

# Database (Supabase PostgreSQL connection string)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:password@db.supabaseproject.supabase.co:5432/postgres
DB_SSL_REQUIRE=True

# CORS - comma separated list of frontend origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.netlify.app
